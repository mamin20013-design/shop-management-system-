# Server
PORT=4000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/dukanpro

# JWT
JWT_SECRET=dukanpro_super_secret_key_2024_change_this_in_production
JWT_EXPIRES_IN=7d

# Shop Admin Password (for registering as Admin role)
SHOP_ADMIN_PASSWORD=shop@admin123

# Frontend URL (for CORS + email verification link)
FRONTEND_URL=http://localhost:3000

# ═══════════════════════════════════════
#  Email / SMTP (required in production)
# ═══════════════════════════════════════
# If these are NOT set the backend logs the verification link in the console.
# For Gmail, enable 2-Step Verification and create an App Password.

SHOP_NAME=DukanPro
SUPPORT_EMAIL=support@yourdomain.com

# SMTP server (e.g. smtp.gmail.com, smtp.sendgrid.net, smtp.mailgun.org)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false

# SMTP login / password (Gmail requires an App Password, not your normal password)
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-character-gmail-app-password

# Sender address shown to recipients
EMAIL_FROM="DukanPro <your-email@gmail.com>"

# Email verification ───────────────────
TOKEN_EXPIRES_IN=25
VERIFICATION_TOKEN_EXPIRES_IN=25
